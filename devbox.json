{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "raylib",
    "premake5@latest",
    "doxygen@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null",
      "devbox run premake"
    ],
    "scripts": {
      "premake": [
        "premake5 clean all",
        "premake5 gmake"
      ],
      "build": [
        "devbox run premake",
        "make config=debug"
      ],
      "dev": [
        "devbox run build",
        "./bin/Debug/arkanoid"
      ],
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
